# Root gitignore for IPO-TRACKER

# Dependency directories
node_modules/
.venv/
env/
venv/
ENV/
bin/
include/

# Next.js build output
.next/
out/
build/
dist/

# Python cache and build files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.egg-info/
.eggs/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# IDEs and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# SQLite databases / local DBs
*.db
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js TypeScript build info
tsconfig.tsbuildinfo
